DATABASE_TARGET=local
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
LOCAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
NEON_DATABASE_URL=postgresql://username:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_POOL_ENABLED=true
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
DATABASE_CONNECT_TIMEOUT=15
DATABASE_APPLICATION_NAME=btq
SEC_CONTACT_NAME=BTQ Research
SEC_CONTACT_EMAIL=you@example.com
POSTGRES_BIN_DIR=
HISTORICAL_DATASET_MIN_EVENT_DATE_QUALITY_SCORE=80
HISTORICAL_DATASET_EVENT_DATE_QUALITY_TIER=high
HISTORICAL_EVENT_EXPORT_LIMIT=100
HISTORICAL_EVENT_EXPORT_OFFSET=0
HISTORICAL_EVENT_EXPORT_MODEL_READY=true
HISTORICAL_EVENT_EXPORT_MAPPED_TICKER=
HISTORICAL_EVENT_EXPORT_PHASE=
HISTORICAL_EVENT_EXPORT_EVENT_DATE_QUALITY_TIER=high
HISTORICAL_EVENT_EXPORT_MIN_EVENT_DATE_QUALITY_SCORE=80
HISTORICAL_EVENT_EXPORT_FORMAT=json
HISTORICAL_EVENT_EXPORT_INCLUDE_SUMMARY=true
EVENT_DATE_REVIEW_EXPORT_LIMIT=100
EVENT_DATE_REVIEW_EXPORT_OFFSET=0
EVENT_DATE_REVIEW_EXPORT_STATUS=pending
EVENT_DATE_REVIEW_EXPORT_TICKER=
EVENT_DATE_REVIEW_EXPORT_EVENT_DATE_QUALITY_TIER=low
EVENT_DATE_REVIEW_EXPORT_FORMAT=json
EVENT_DATE_REVIEW_EXPORT_INCLUDE_SUMMARY=true
